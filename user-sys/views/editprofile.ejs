<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Edit Profile</title>
    <script src="https://cdn.tailwindcss.com"></script>
  </head>
  <body class="bg-gray-100 flex items-center justify-center min-h-screen">
    <div class="bg-white p-8 rounded-lg shadow-lg w-full max-w-md">
      <div class="flex justify-center mb-6">
        <span class="text-3xl font-bold text-indigo-600">BrandLogo</span>
      </div>

        <h2 class="text-2xl font-semibold text-center text-gray-800 mb-6">
        Edit Profile
      </h2>
      <p class="text-center text-gray-600 mb-6">Update your name, image and other details below.</p>

<form action="/updateprofile" method="post" enctype="multipart/form-data">
        <!-- Full Name -->
        <div class="mb-4">
          <label
            for="fullname"
            class="block text-gray-700 text-sm font-bold mb-2"
          >
            Full Name
          </label>
            <input
            type="text"
            id="fullname"
            name="fullname"
            value="<%= user.fullname %>"
            class="w-full px-4 py-2 border rounded-lg focus:outline-none focus:ring-2 focus:ring-indigo-500 border-gray-300"
            required
          />
        </div>

        <!-- email -->
        <div class="mb-4">
          <label for="email" class="block text-gray-700 text-sm font-bold mb-2">
            Email Address
          </label>
            <input
            type="email"
            id="email"
            name="email"
            value="<%= user.email %>"
            class="w-full px-4 py-2 border rounded-lg focus:outline-none focus:ring-2 focus:ring-indigo-500 border-gray-300"
            required
          />
        </div>

        <!-- username -->
        <div class="mb-4">
          <label
            for="username"
            class="block text-gray-700 text-sm font-bold mb-2"
          >
            User Name
          </label>
            <input
            type="text"
            id="uname"
            name="username"
            value="<%= user.username || '' %>"
            class="w-full px-4 py-2 border rounded-lg focus:outline-none focus:ring-2 focus:ring-indigo-500 border-gray-300"
            required
          />
        </div>

        <!-- Phone Number -->
        <div class="mb-4">
          <label for="phone" class="block text-gray-700 text-sm font-bold mb-2">
            Phone Number
          </label>
          <input
            type="tel"
            id="phone"
            name="phone"
            value="<%= user.phone || '' %>"
            class="w-full px-4 py-2 border rounded-lg focus:outline-none focus:ring-2 focus:ring-indigo-500 border-gray-300"
            required
          />
        </div>

        <!-- profile image -->
        <div class="mb-4">
          <label for="pimg" class="block text-gray-700 text-sm font-bold mb-2">
            Profile Image
          </label>
            <!-- Current image preview -->
            <% if (user.image) { %>
            <div class="mb-2 p-4 bg-gray-50 rounded-lg text-center">
              <img src="/uploads/<%= user.image %>" alt="Current profile" class="h-24 w-24 mx-auto rounded-full object-cover mb-2 shadow-md" />
              <p class="text-sm text-gray-600">Current profile image</p>
            </div>
            <% } %>
            <input
              type="file"
              id="pimg"
              name="image"
              accept="image/*"
              class="w-full px-4 py-2 border rounded-lg focus:outline-none focus:ring-2 focus:ring-indigo-500 border-gray-300"
            />
        </div>



        <button
          type="submit"
          class="w-full bg-indigo-600 text-white font-bold py-2 px-4 rounded-lg hover:bg-indigo-700 transition duration-300"
        >
          Update Profile
        </button>
      </form>

      <div class="mt-6 text-center">
        <a href="/profile" class="text-indigo-600 hover:underline font-semibold">← Back to Profile</a>
      </div>
    </div>
  </body>
</html>
 